# Copy to .env and edit for your machine:
#   cp .env.example .env
#
# Usage:
#   docker compose --env-file .env up --build -d

# --- HTTP ---
HOST_PORT=5000
CONTAINER_PORT=5000
# Bind published port only on this host address (your LAN IP). Use 0.0.0.0 for all interfaces.
BIND_IP=0.0.0.0

# Optional: require clients to send header X-API-Key: <value>
# GEMMA_API_KEY=change-me

# Prepended as the first system turn on every /chat/stream, /image/stream, /video/stream request.
# If the client also sends role=system, server + client system text are merged into one turn.
# To skip prepending when the client already sent role=system (legacy): GEMMA_DEFAULT_SYSTEM_RESPECT_CLIENT_SYSTEM=1
# If you use RESPECT but still want the server line first: GEMMA_DEFAULT_SYSTEM_FORCE_PREPEND=1
# Example (uncomment one line in your real .env):
# GEMMA_DEFAULT_SYSTEM_PROMPT=You are a helpful assistant. Answer clearly and concisely.
# GEMMA_DEFAULT_SYSTEM_PROMPT=Act as an expert radiologist and clinical assistant (informational only; not a substitute for a licensed physician).

# --- vLLM (stream routes: /chat/stream, /image/stream, /video/stream) ---
# Dockerfile uses vllm/vllm-openai:gemma4-cu130 by default.
GEMMA_API_BACKEND=vllm
GEMMA_SKIP_HF_MODEL=1

NVIDIA_VISIBLE_DEVICES=all
GEMMA_VLLM_TP_SIZE=2
GEMMA_VLLM_MAX_MODEL_LEN=8192
GEMMA_VLLM_GPU_MEMORY_UTILIZATION=0.95
GEMMA_VLLM_TRUST_REMOTE_CODE=1

# --- Hugging Face in-process model (only when GEMMA_SKIP_HF_MODEL=0 or HF-only image) ---
# With GEMMA_SKIP_HF_MODEL=1 the HF model is NOT loaded (saves VRAM). Stream endpoints use vLLM only.
# To load BOTH vLLM + HF (needs a lot of VRAM — usually avoid):
#   GEMMA_SKIP_HF_MODEL=0
GEMMA_REQUIRE_GPU=1
# Used mainly when GEMMA_SKIP_HF_MODEL=0 (HF path). For a single full GPU try cuda0; for split across GPUs use auto + caps:
GEMMA_DEVICE_MAP=auto
GEMMA_MAX_MEMORY_GPU=44GiB
# GEMMA_MAX_MEMORY_CPU=48GiB

# Optional HF quantization (only when HF model is loaded)
# GEMMA_LOAD_4BIT=1
# GEMMA_LOAD_8BIT=1

# --- Logging ---
GEMMA_LOG_CONFIGURE=1
GEMMA_WEIGHTS_TQDM=1
GEMMA_LOAD_HEARTBEAT=1
GEMMA_LOAD_HEARTBEAT_SEC=10

# --- Model & data mounts ---
HOST_MODEL_DIR=./gemma-4-E4B-it
# HOST_MODEL_DIR=./medgemma-27b-it
HOST_IMAGES_DIR=./images
GEMMA_MODEL_PATH=/model
GEMMA_IMAGES_DIR=/images

# Multipart uploads (writable path inside container)
# GEMMA_UPLOAD_TMP_DIR=/tmp/gemma4-uploads

# Audio: 0 = librosa path in HF stack; mostly irrelevant when GEMMA_SKIP_HF_MODEL=1
GEMMA_USE_TORCHCODEC=0

# Optional vision tuning (HF processor path; vLLM has its own defaults in gemma_vllm.py)
# GEMMA_VIDEO_NUM_FRAMES=16
# GEMMA_VIDEO_MAX_SOFT_TOKENS=70
# GEMMA_IMAGE_MAX_SOFT_TOKENS=280

# Optional: timing logs for debugging (PERF lines in container logs)
# GEMMA_PERF_LOG=1
