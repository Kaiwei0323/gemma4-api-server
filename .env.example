# Copy to .env and edit values.
#
# Usage:
#   docker compose --env-file .env up --build -d
#
# Note: "different IP" is controlled by the machine you run Docker on and its firewall/NAT.
# This file mainly controls port mapping and app/model settings.

# Host port you want to expose on your machine (outside the container).
HOST_PORT=5000

# Container port uvicorn listens on (inside container). Usually leave as 5000.
CONTAINER_PORT=5000

# Host IP interface to bind the published port to.
# - 0.0.0.0  = listen on all interfaces (LAN + localhost)
# - 127.0.0.1 = localhost only (not reachable from other machines)
# - <your LAN IP> = bind only to that interface
BIND_IP=0.0.0.0

# Optional API key. If set, clients must send header: X-API-Key: <value>
# GEMMA_API_KEY=change-me

# GPU behavior
GEMMA_REQUIRE_GPU=1

# cuda0 = entire model on GPU 0 (fine for smaller checkpoints; 31B bf16 will OOM on a single 48GB card).
# For gemma-4-31B-it on two GPUs (e.g. 2× NVIDIA L40S), expose both devices and let Hugging Face split layers:
#   NVIDIA_VISIBLE_DEVICES=all
#   GEMMA_DEVICE_MAP=auto
# Optional: cap each GPU so some VRAM stays free for activations / KV cache (per-GPU, repeats for GPU 0,1,…):
#   GEMMA_MAX_MEMORY_GPU=44GiB
GEMMA_DEVICE_MAP=cuda0

# If you OOM on a single GPU, try:
# GEMMA_DEVICE_MAP=auto
# GEMMA_MAX_MEMORY_GPU=10GiB
# GEMMA_MAX_MEMORY_CPU=48GiB

# Optional quantization (requires bitsandbytes inside the image)
# GEMMA_LOAD_4BIT=1
# GEMMA_LOAD_8BIT=1

# Logging / load progress in docker logs
GEMMA_LOG_CONFIGURE=1
GEMMA_WEIGHTS_TQDM=1
GEMMA_LOAD_HEARTBEAT=1
GEMMA_LOAD_HEARTBEAT_SEC=10

# Bind-mount locations on the HOST (relative paths are relative to docker-compose.yml directory)
HOST_MODEL_DIR=./gemma-4-E4B-it
# Example for 31B: HOST_MODEL_DIR=./gemma-4-31B-it
HOST_IMAGES_DIR=./images

# Mount points inside the CONTAINER (usually leave as-is)
GEMMA_MODEL_PATH=/model
GEMMA_IMAGES_DIR=/images

# Where multipart /image uploads are staged inside the container (must be writable).
# Default if unset: /tmp/gemma4-uploads
# GEMMA_UPLOAD_TMP_DIR=/tmp/gemma4-uploads

# Audio decoding: Transformers may try `torchcodec` if installed, but it often breaks in slim Docker images.
# Default 0 forces the librosa decoding path. Set to 1 only if you have a working torchcodec+ffmpeg setup.
GEMMA_USE_TORCHCODEC=0

# Optional: faster / lighter vision preprocessing for /video and /image (see README).
# GEMMA_VIDEO_NUM_FRAMES=16
# GEMMA_VIDEO_MAX_SOFT_TOKENS=70
# GEMMA_IMAGE_MAX_SOFT_TOKENS=280

